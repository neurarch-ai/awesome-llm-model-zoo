/**
 * Model-zoo generator (maintainers only).
 *
 * Builds every architecture entry (model.json + assets/diagram.svg + README.md)
 * from verified specs, using the Neurarch source checkout expected at a
 * sibling directory (../Neurarch). Run from the zoo repo root:
 *
 *   npx tsx --tsconfig ../Neurarch/tsconfig.json scripts/generate.mts
 *
 * Entry sources:
 *  - decoder/encoder specs: hand-verified against the official config.json on HF
 *  - template entries: copied from Neurarch's in-app template library
 *  - parser entries: generated by Neurarch's paper-architecture parser
 *
 * Every graph is validated with Neurarch's own shape propagator before it is
 * written; the script fails loudly on any shape error.
 */
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const NEURARCH = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../Neurarch');
const ZOO = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');

const { exportPaperSvg } = await import(path.join(NEURARCH, 'src/utils/figureExporter.ts'));
const { propagateShapes } = await import(path.join(NEURARCH, 'src/utils/shapeInference.ts'));
const { parsePaperTextToModel } = await import(path.join(NEURARCH, 'src/utils/paperArchitectureParser.ts'));

// ---------------------------------------------------------------------------
// Spec types
// ---------------------------------------------------------------------------

type Link = [label: string, url: string];

interface DecoderSpec {
  kind: 'decoder';
  id: string; displayName: string; org: string; paramsLabel: string;
  github: string; hf: string; license: string;
  hidden: number; layers: number; heads: number; kvHeads: number;
  ffn: number; vocab: number; ctx: number; ropeDim: number;
  notes: string[]; blurb: string;
}

interface EncoderSpec {
  kind: 'encoder';
  id: string; displayName: string; org: string; paramsLabel: string;
  github: string; hf: string; license: string;
  hidden: number; layers: number; heads: number; ffn: number;
  vocab: number; maxPos: number;
  notes: string[]; blurb: string;
}

interface TemplateEntry {
  kind: 'template';
  tid: string; // folder under Neurarch public/templates
  id: string;  // zoo folder id
  displayName: string; org: string; paramsLabel: string;
  links: Link[]; license?: string;
  blurb: string; notes: string[];
  patch?: (model: { components: Array<{ name: string; params: Record<string, unknown> }> }) => void;
}

interface ParserEntry {
  kind: 'parser';
  parseName: string; // name fed to parsePaperTextToModel
  id: string; displayName: string; org: string; paramsLabel: string;
  links: Link[]; license?: string;
  blurb: string; notes: string[];
}

type Spec = DecoderSpec | EncoderSpec | TemplateEntry | ParserEntry;

