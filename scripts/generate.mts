// Main
// ---------------------------------------------------------------------------

function wireAndValidate(model: { id: string; components: Comp[]; connections: Conn[] }): number {
  for (const c of model.components) { c.inputs = []; c.outputs = []; }
  const byId = new Map(model.components.map((c) => [c.id, c]));
  for (const conn of model.connections) {
    byId.get(conn.from)!.outputs.push(conn.to);
    byId.get(conn.to)!.inputs.push(conn.from);
  }
  const result = propagateShapes(model as never);
  const errors = (result.issues ?? []).filter((i: { severity: string }) => i.severity === 'error');
  if (errors.length) {
    console.error(`✗ ${model.id}: shape errors`, errors);
    throw new Error(`shape errors in ${model.id}`);
  }
  return (result.issues ?? []).length;
}

function writeEntry(id: string, model: object, readme: string) {
  const dir = path.join(ZOO, 'architectures', id);
  fs.mkdirSync(path.join(dir, 'assets'), { recursive: true });
  fs.writeFileSync(path.join(dir, 'model.json'), JSON.stringify(model, null, 2) + '\n');
  fs.writeFileSync(path.join(dir, 'assets', 'diagram.svg'), exportPaperSvg(model as never, { attribution: true }));
  fs.writeFileSync(path.join(dir, 'README.md'), readme);
}

const ALL: Spec[] = [...DECODERS, ...ENCODERS, ...TEMPLATES, ...PARSED];
let count = 0;
for (const s of ALL) {
  if (s.kind === 'decoder' || s.kind === 'encoder') {
    const model = s.kind === 'decoder' ? buildDecoder(s) : buildEncoder(s);
    const warnings = wireAndValidate(model);
    writeEntry(s.id, model, renderSpecReadme(s));
    console.log(`✓ ${s.id} [${s.kind}] (${model.components.length} components, ${warnings} warnings)`);
  } else if (s.kind === 'template') {
    const src = path.join(NEURARCH, 'public/templates', s.tid, 'model.json');
    const model = JSON.parse(fs.readFileSync(src, 'utf8'));
    model.id = s.id;
    s.patch?.(model);
    const warnings = wireAndValidate(model);
    writeEntry(s.id, model, renderEntryReadme(s, model));
    console.log(`✓ ${s.id} [template] (${model.components.length} components, ${warnings} warnings)`);
  } else {
    const r = parsePaperTextToModel(s.parseName);
    if (!r.model) throw new Error(`parser returned no model for ${s.parseName}`);
    const model = {
      id: s.id, name: s.displayName,
      description: `${s.displayName} (${s.org}). Generated by Neurarch's architecture parser; shape-validated end to end.`,
      components: r.model.components, connections: r.model.connections,
    };
    const warnings = wireAndValidate(model as never);
    writeEntry(s.id, model, renderEntryReadme(s, model as never));
    console.log(`✓ ${s.id} [parser] (${model.components.length} components, ${warnings} warnings)`);
  }
  count++;
}
console.log(`\nDone: ${count} entries. Convert SVGs to PNG separately (resvg), then update the top-level catalog.`);
