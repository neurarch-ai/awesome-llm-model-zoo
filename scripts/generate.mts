/**
 * Model-zoo generator (maintainers only).
 *
 * Builds every architecture entry (model.json + assets/ + README.md) using the
 * Neurarch source checkout expected at a sibling directory (../Neurarch).
 * Run from the zoo repo root:
 *
 *   npx tsx --tsconfig ../Neurarch/tsconfig.json scripts/generate.mts
 *
 * Entry sources:
 *  - full models (decoder / encoder / hffull): imported with the SAME code path
 *    the app uses for "load from Hugging Face" (loadHFModel), then patched where
 *    the importer is known-wrong, so model.json is what you would get by loading
 *    the HF model in Neurarch and saving.
 *  - template entries: copied from Neurarch's in-app template library
 *  - parser entries: generated by Neurarch's paper-architecture parser
 *
 * Two hard gates, the build fails on either:
 *  1. Shape propagation must report zero errors.
 *  2. For full models, Neurarch's per-layer parameter estimate over the graph
 *     must land within tolerance (default 10%) of the real parameter count
 *     (HF safetensors metadata, or the official figure), unless the deviation
 *     is explained weight tying (tyingNote).
 *
 * Assets per full-model entry:
 *  - assets/diagram.svg|png : the FULL imported graph (what model.json holds)
 *  - assets/block.svg|png   : compact one-block explainer view
 */
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const NEURARCH = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../Neurarch');
const ZOO = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');

const { exportPaperSvg, foldRepeatedBlocks } = await import(path.join(NEURARCH, 'src/utils/figureExporter.ts'));
const { propagateShapes, annotateModelShapes } = await import(path.join(NEURARCH, 'src/utils/shapeInference.ts'));
const { parsePaperTextToModel } = await import(path.join(NEURARCH, 'src/utils/paperArchitectureParser.ts'));
const { loadHFModel } = await import(path.join(NEURARCH, 'src/utils/hfModelLoader.ts'));
const { estimateLayerParams } = await import(path.join(NEURARCH, 'src/utils/paramEstimator.ts'));
const { Resvg } = await import('@resvg/resvg-js');
const { PNG } = await import('pngjs');

// ---------------------------------------------------------------------------
// Spec types
// ---------------------------------------------------------------------------

type Link = [label: string, url: string];

interface Comp {
  id: string; type: string; name: string; scope?: string;
  position: { x: number; y: number };
  params: Record<string, unknown>;
  notes?: string;
  inputs: string[]; outputs: string[];
}
interface Conn { id: string; from: string; to: string }
interface Graph { id: string; name: string; description?: string; components: Comp[]; connections: Conn[]; realParamCount?: number; approxParams?: boolean }

interface FullModelFields {
  /** HF repo whose config.json drives the import (mirror when official is gated) */
  hfId?: string;
  /** build the full graph by hand instead of importing (importer known-broken) */
  fullBuild?: () => Graph;
  /** surgical fixes applied to the imported graph */
  hfPatch?: (m: Graph) => void;
  /** authoritative param count when safetensors metadata is missing or double-counts tied weights */
  officialParams?: number;
  /** explanation when naive per-layer sums differ from the real count (weight tying) */
  tyingNote?: string;
  /** param-gate tolerance override (default 0.10) */
  paramTolerance?: number;
}

interface DecoderSpec extends FullModelFields {
  kind: 'decoder';
  id: string; displayName: string; org: string; paramsLabel: string;
  github: string; hf: string; license: string;
  hidden: number; layers: number; heads: number; kvHeads: number;
  ffn: number; vocab: number; ctx: number; ropeDim: number;
  headDim?: number;
  qkNorm?: boolean;
  ffnKind?: 'swiglu' | 'geglu';
  moe?: { numExperts: number; topK: number; expertDim: number; sharedExpert?: boolean; denseFirstK?: number };
  mla?: { kvLatentDim: number; qLatentDim?: number; ropeHeadDim: number; nopeHeadDim: number; vHeadDim: number };
  posLabel?: string;
  notes: string[]; blurb: string;
}

interface EncoderSpec extends FullModelFields {
  kind: 'encoder';
  id: string; displayName: string; org: string; paramsLabel: string;
  github: string; hf: string; license: string;
  hidden: number; layers: number; heads: number; ffn: number;
  vocab: number; maxPos: number;
  notes: string[]; blurb: string;
}

interface HFFullEntry extends FullModelFields {
  kind: 'hffull';
  id: string; displayName: string; org: string; paramsLabel: string;
  links: Link[]; license?: string;
  blurb: string; notes: string[];
  /** hand-written hyperparameter table rows */
  archRows: Array<[string, string]>;
  /** Neurarch template id used for the compact block view (optional) */
  blockTemplate?: string;
}

interface TemplateEntry {
  kind: 'template';
  tid: string;
  id: string;
  displayName: string; org: string; paramsLabel: string;
  links: Link[]; license?: string;
  blurb: string; notes: string[];
  patch?: (model: Graph) => void;
}

interface ParserEntry {
  kind: 'parser';
  parseName: string;
  id: string; displayName: string; org: string; paramsLabel: string;
  links: Link[]; license?: string;
  blurb: string; notes: string[];
  officialParams?: number;
  patch?: (m: Graph) => void;
}

type Spec = DecoderSpec | EncoderSpec | HFFullEntry | TemplateEntry | ParserEntry;

