// ---------------------------------------------------------------------------
// Block-view builders (compact one-block explainer graphs)
// ---------------------------------------------------------------------------

function buildDecoderBlockView(s: DecoderSpec): Graph {
  const comps: Comp[] = [];
  const conns: Conn[] = [];
  let y = 50; const X = 300; const STEP = 150; let ci = 0;
  const add = (type: string, name: string, params: Record<string, unknown>, opts: { scope?: string; notes?: string; x?: number; sameRow?: boolean } = {}) => {
    if (!opts.sameRow) y += STEP;
    const c: Comp = { id: `${type}-${comps.length + 1}`, type, name, position: { x: opts.x ?? X, y }, params, inputs: [], outputs: [] };
    if (opts.scope) c.scope = opts.scope;
    if (opts.notes) c.notes = opts.notes;
    comps.push(c);
    return c;
  };
  const wire = (from: Comp, to: Comp) => { conns.push({ id: `c${++ci}`, from: from.id, to: to.id }); };

  const seqLen = Math.min(s.ctx, 4096);
  const headDim = s.headDim ?? s.hidden / s.heads;

  y -= STEP;
  const inp = add('input', 'tokens', { shape: [1, seqLen] });
  const emb = add('embedding', 'token_embed', { numEmbeddings: s.vocab, embeddingDim: s.hidden }, { scope: 'embeddings' });
  wire(inp, emb);
  const normA = add('rmsNorm', 'attn_norm', { normalizedShape: s.hidden }, { scope: 'layer.0.attention', notes: `One of ${s.layers} decoder blocks shown.` });
  wire(emb, normA);
  const attn = s.mla
    ? add('mla', 'self_attn', { embedDim: s.hidden, numHeads: s.heads, kvLatentDim: s.mla.kvLatentDim, ropeHeadDim: s.mla.ropeHeadDim }, { scope: 'layer.0.attention' })
    : s.kvHeads < s.heads
      ? add('groupedQueryAttention', 'self_attn', { embedDim: s.hidden, numHeads: s.heads, numKVHeads: s.kvHeads }, { scope: 'layer.0.attention' })
      : add('causalAttention', 'self_attn', { embedDim: s.hidden, numHeads: s.heads }, { scope: 'layer.0.attention' });
  wire(normA, attn);
  const rope = add('rope', 'rope', { dim: s.ropeDim }, { scope: 'layer.0.attention', x: X + 280, sameRow: true });
  wire(rope, attn);
  if (s.qkNorm) {
    const qk = add('qkNorm', 'qk_norm', { dim: headDim }, { scope: 'layer.0.attention', x: X + 280 });
    wire(qk, attn);
  }
  const res1 = add('add', 'residual_1', {}, { scope: 'layer.0.attention' });
  wire(attn, res1); wire(emb, res1);
  const normF = add('rmsNorm', 'ffn_norm', { normalizedShape: s.hidden }, { scope: 'layer.0.ffn' });
  wire(res1, normF);
  let ffnOut: Comp;
  if (s.moe) {
    const moe = add('moeLayer', 'routed_experts', { embedDim: s.hidden, numExperts: s.moe.numExperts, topK: s.moe.topK, expertDim: s.moe.expertDim }, { scope: 'layer.0.ffn' });
    wire(normF, moe);
    if (s.moe.sharedExpert) {
      const shared = add('swiglu', 'shared_expert', { embedDim: s.hidden, intermediateSize: s.moe.expertDim }, { scope: 'layer.0.ffn', x: X + 280 });
      wire(normF, shared);
      const sum = add('add', 'expert_sum', {}, { scope: 'layer.0.ffn' });
      wire(moe, sum); wire(shared, sum);
      ffnOut = sum;
    } else { ffnOut = moe; }
  } else if (s.ffnKind === 'geglu') {
    ffnOut = add('geglu', 'geglu_ffn', { dim: s.hidden, hiddenDim: s.ffn }, { scope: 'layer.0.ffn' });
    wire(normF, ffnOut);
  } else {
    ffnOut = add('swiglu', 'swiglu_ffn', { embedDim: s.hidden, intermediateSize: s.ffn }, { scope: 'layer.0.ffn' });
    wire(normF, ffnOut);
  }
  const res2 = add('add', 'residual_2', {}, { scope: 'layer.0.ffn' });
  wire(ffnOut, res2); wire(res1, res2);
  const normOut = add('rmsNorm', 'final_norm', { normalizedShape: s.hidden }, { scope: 'norm' });
  wire(res2, normOut);
  const head = add('linear', 'lm_head', { inFeatures: s.hidden, outFeatures: s.vocab }, { scope: 'head' });
  wire(normOut, head);
  const out = add('output', 'logits', {});
  wire(head, out);

  return { id: `${s.id}-block-view`, name: `${s.displayName} (block view)`, components: comps, connections: conns };
}

function buildEncoderBlockView(s: EncoderSpec): Graph {
  const comps: Comp[] = [];
  const conns: Conn[] = [];
  let y = 50; const X = 300; const STEP = 150; let ci = 0;
  const add = (type: string, name: string, params: Record<string, unknown>, opts: { scope?: string; notes?: string } = {}) => {
    const c: Comp = { id: `${type}-${comps.length + 1}`, type, name, position: { x: X, y }, params, inputs: [], outputs: [] };
    if (opts.scope) c.scope = opts.scope;
    if (opts.notes) c.notes = opts.notes;
    comps.push(c);
    y += STEP;
    return c;
  };
  const wire = (from: Comp, to: Comp) => { conns.push({ id: `c${++ci}`, from: from.id, to: to.id }); };

  const inp = add('input', 'input_ids', { shape: [1, s.maxPos] });
  const emb = add('embedding', 'word_embed', { numEmbeddings: s.vocab, embeddingDim: s.hidden }, { scope: 'embeddings' });
  wire(inp, emb);
  const pos = add('positionalEncoding', 'pos_embed', { maxLen: s.maxPos, embedDim: s.hidden }, { scope: 'embeddings' });
  wire(emb, pos);
  const eNorm = add('layerNorm', 'embed_norm', { normalizedShape: s.hidden }, { scope: 'embeddings' });
  wire(pos, eNorm);
  const drop = add('dropout', 'embed_drop', { p: 0.1 }, { scope: 'embeddings' });
  wire(eNorm, drop);
  const attn = add('multiHeadAttention', 'self_attn', { embedDim: s.hidden, numHeads: s.heads }, { scope: 'layer.0.attention', notes: `One of ${s.layers} encoder blocks shown.` });
  wire(drop, attn);
  const res1 = add('add', 'residual_1', {}, { scope: 'layer.0.attention' });
  wire(attn, res1); wire(drop, res1);
  const n1 = add('layerNorm', 'attn_norm', { normalizedShape: s.hidden }, { scope: 'layer.0.attention' });
  wire(res1, n1);
  const ffn = add('feedForward', 'ffn', { embedDim: s.hidden, ffDim: s.ffn }, { scope: 'layer.0.ffn' });
  wire(n1, ffn);
  const res2 = add('add', 'residual_2', {}, { scope: 'layer.0.ffn' });
  wire(ffn, res2); wire(n1, res2);
  const n2 = add('layerNorm', 'ffn_norm', { normalizedShape: s.hidden }, { scope: 'layer.0.ffn' });
  wire(res2, n2);
  const out = add('output', 'hidden_states', {});
  wire(n2, out);

  return { id: `${s.id}-block-view`, name: `${s.displayName} (block view)`, components: comps, connections: conns };
}

// ---------------------------------------------------------------------------
// Shared pipeline helpers
// ---------------------------------------------------------------------------

const RAW_BASE = 'https://raw.githubusercontent.com/neurarch-ai/neurarch-model-zoo/main/architectures';
const openUrl = (id: string) => `https://www.neurarch.com/?import=${RAW_BASE}/${id}/model.json`;
const fmtP = (n: number) => n >= 1e12 ? (n / 1e12).toFixed(2) + 'T' : n >= 1e9 ? (n / 1e9).toFixed(2) + 'B' : n >= 1e6 ? (n / 1e6).toFixed(1) + 'M' : (n / 1e3).toFixed(1) + 'K';

function wireGraph(model: Graph) {
  for (const c of model.components) { c.inputs = []; c.outputs = []; }
  const byId = new Map(model.components.map((c) => [c.id, c]));
  for (const conn of model.connections) {
    byId.get(conn.from)!.outputs.push(conn.to);
    byId.get(conn.to)!.inputs.push(conn.from);
  }
}

function validateShapes(model: Graph): number {
  const result = propagateShapes(model as never);
  const errors = (result.issues ?? []).filter((i: { severity: string }) => i.severity === 'error');
  if (errors.length) {
    console.error(`✗ ${model.id}: shape errors`, errors.slice(0, 4));
    throw new Error(`shape errors in ${model.id}`);
  }
  return (result.issues ?? []).length;
}

/** Stable sequential ids so regeneration does not churn git diffs. */
function normalizeIds(model: Graph) {
  const map = new Map<string, string>();
  model.components.forEach((c, i) => { map.set(c.id, `n${i + 1}`); });
  for (const c of model.components) c.id = map.get(c.id)!;
  model.connections.forEach((conn, i) => {
    conn.id = `c${i + 1}`;
    conn.from = map.get(conn.from)!;
    conn.to = map.get(conn.to)!;
  });
}

/** Fill conv inChannels / linear inFeatures from propagated shapes so the
 *  in-app StatsBar (which reads params only) counts them correctly. */
function fillShapeDerivedParams(model: Graph) {
  const annotated = annotateModelShapes(structuredClone(model) as never) as unknown as Graph & { components: Array<Comp & { inputShape?: number[] }> };
  const shapeById = new Map(annotated.components.map((c) => [c.id, (c as { inputShape?: number[] }).inputShape]));
  for (const c of model.components) {
    const inShape = shapeById.get(c.id);
    if (!inShape || !inShape.length) continue;
    if ((c.type === 'conv2d' || c.type === 'conv1d') && c.params.inChannels == null) {
      // channels-first [C, ...] (no batch dim in the CNN templates/parser graphs)
      c.params.inChannels = inShape.length >= 3 ? inShape[inShape.length - 3] : inShape[0];
    }
    if (c.type === 'linear' && c.params.inFeatures == null) {
      c.params.inFeatures = inShape[inShape.length - 1];
    }
  }
}

function estimateGraphParams(model: Graph): number {
  return model.components.reduce((s, c) => s + estimateLayerParams(c.type, c.params, []), 0);
}

interface ParamCheck { est: number; expected?: number; devPct?: number }

function paramGate(id: string, model: Graph, f: FullModelFields & { paramsLabel?: string }): ParamCheck {
  const est = estimateGraphParams(model);
  const expected = f.officialParams ?? model.realParamCount;
  if (!expected) return { est };
  const dev = (est - expected) / expected;
  const tol = f.paramTolerance ?? 0.10;
  if (Math.abs(dev) > tol) {
    throw new Error(`param gate failed for ${id}: est ${fmtP(est)} vs expected ${fmtP(expected)} (${(dev * 100).toFixed(1)}%, tol ${tol * 100}%)`);
  }
  return { est, expected, devPct: dev * 100 };
}

async function importFullGraph(s: FullModelFields, id: string, name: string, description: string): Promise<Graph> {
  let model: Graph;
  if (s.fullBuild) {
    model = s.fullBuild();
  } else {
    const imported = await loadHFModel(s.hfId!);
    if (!imported) throw new Error(`loadHFModel returned null for ${s.hfId}`);
    if ((imported as { approxParams?: boolean }).approxParams) throw new Error(`config for ${s.hfId} fell back to a generic template; refusing to ship`);
    model = imported as unknown as Graph;
  }
  s.hfPatch?.(model);
  model.id = id;
  model.name = name;
  model.description = description;
  delete model.approxParams;
  normalizeIds(model);
  wireGraph(model);
  fillShapeDerivedParams(model);
  return model;
}

