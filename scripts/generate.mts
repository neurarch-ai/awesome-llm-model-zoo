function buildWhisperFull(): Graph {
  const comps: Comp[] = []; const conns: Conn[] = []; let ci = 0;
  const add = (type: string, name: string, params: Record<string, unknown>, x: number, y: number, opts: { scope?: string; notes?: string } = {}) => {
    const c: Comp = { id: `${type}-${comps.length + 1}`, type, name, position: { x, y }, params, inputs: [], outputs: [] };
    if (opts.scope) c.scope = opts.scope; if (opts.notes) c.notes = opts.notes;
    comps.push(c); return c;
  };
  const wire = (a: Comp, b: Comp) => { conns.push({ id: `c${++ci}`, from: a.id, to: b.id }); };
  // encoder
  let y = 50;
  const mel = add('input', 'mel_features', { shape: [80, 3000] }, 150, y, { notes: '80-channel log-mel spectrogram, 30s of audio at 100 frames/s.' });
  y += 150;
  const c1 = add('conv1d', 'conv1', { inChannels: 80, outChannels: 768, kernelSize: 3, padding: 1 }, 150, y, { scope: 'encoder.stem' }); wire(mel, c1);
  y += 150;
  const g1 = add('gelu', 'gelu_1', {}, 150, y, { scope: 'encoder.stem' }); wire(c1, g1);
  y += 150;
  const c2 = add('conv1d', 'conv2', { inChannels: 768, outChannels: 768, kernelSize: 3, stride: 2, padding: 1 }, 150, y, { scope: 'encoder.stem', notes: '2x temporal downsample: 3000 frames become 1500 positions.' }); wire(g1, c2);
  y += 150;
  const g2 = add('gelu', 'gelu_2', {}, 150, y, { scope: 'encoder.stem' }); wire(c2, g2);
  y += 150;
  const ePos = add('positionalEncoding', 'enc_pos', { maxLen: 1500, embedDim: 768 }, 150, y, { scope: 'encoder', notes: 'Fixed sinusoidal positions.' }); wire(g2, ePos);
  let prev = ePos;
  for (let i = 0; i < 12; i++) {
    y += 150;
    const b = add('transformerBlock', `enc_block_${i + 1}`, { embedDim: 768, numHeads: 12, ffDim: 3072 }, 150, y, { scope: `encoder.layer.${i}`, notes: i === 0 ? 'Pre-norm encoder block: MHA(12) + GeLU MLP(3072). One of 12.' : undefined });
    wire(prev, b); prev = b;
  }
  y += 150;
  const eNorm = add('layerNorm', 'enc_norm', { normalizedShape: 768 }, 150, y, { scope: 'encoder' }); wire(prev, eNorm);
  // decoder
  let yd = 50;
  const tok = add('input', 'decoder_tokens', { shape: [1, 448] }, 650, yd, { notes: 'Text tokens (max 448), prefixed with task/language special tokens.' });
  yd += 150;
  const emb = add('embedding', 'token_embed', { numEmbeddings: 51865, embeddingDim: 768 }, 650, yd, { scope: 'decoder', notes: '51865-token multilingual BPE vocabulary. Tied with the output projection.' }); wire(tok, emb);
  yd += 150;
  const dPos = add('positionalEncoding', 'dec_pos', { maxLen: 448, embedDim: 768 }, 650, yd, { scope: 'decoder', notes: 'Learned positions.' }); wire(emb, dPos);
  let dPrev = dPos;
  for (let i = 0; i < 12; i++) {
    yd += 150;
    const sa = add('transformerBlock', `dec_block_${i + 1}`, { embedDim: 768, numHeads: 12, ffDim: 3072 }, 650, yd, { scope: `decoder.layer.${i}`, notes: i === 0 ? 'Causal self-attention + GeLU MLP. One of 12.' : undefined });
    wire(dPrev, sa);
    yd += 150;
    const ca = add('crossAttention', `cross_attn_${i + 1}`, { embedDim: 768, numHeads: 12 }, 650, yd, { scope: `decoder.layer.${i}`, notes: i === 0 ? 'Cross-attention into the encoder output. One of 12.' : undefined });
    wire(sa, ca); wire(eNorm, ca);
    dPrev = ca;
  }
  yd += 150;
  const dNorm = add('layerNorm', 'dec_norm', { normalizedShape: 768 }, 650, yd, { scope: 'decoder' }); wire(dPrev, dNorm);
  yd += 150;
  const out = add('output', 'token_logits', {}, 650, yd, { notes: 'Logits via the tied token-embedding matrix (no separate LM head weights).' });
  wire(dNorm, out);
  return {
    id: 'whisper-small', name: 'Whisper Small',
    description: 'Whisper Small (OpenAI): speech-to-text encoder-decoder. Conv stem + 12 encoder blocks; 12 decoder blocks each with cross-attention into the encoder; tied output embedding. Full graph; dims verified against the official config.json.',
    components: comps, connections: conns,
  };
}

function buildClipFull(): Graph {
  const comps: Comp[] = []; const conns: Conn[] = []; let ci = 0;
  const add = (type: string, name: string, params: Record<string, unknown>, x: number, y: number, opts: { scope?: string; notes?: string } = {}) => {
    const c: Comp = { id: `${type}-${comps.length + 1}`, type, name, position: { x, y }, params, inputs: [], outputs: [] };
    if (opts.scope) c.scope = opts.scope; if (opts.notes) c.notes = opts.notes;
    comps.push(c); return c;
  };
  const wire = (a: Comp, b: Comp) => { conns.push({ id: `c${++ci}`, from: a.id, to: b.id }); };
  // vision tower
  let y = 50;
  const img = add('input', 'image', { shape: [1, 3, 224, 224] }, 150, y);
  y += 150;
  const patch = add('patchEmbed', 'patch_embed', { imgSize: 224, patchSize: 32, embedDim: 768, inChans: 3 }, 150, y, { scope: 'vision', notes: '32x32 patches: 224x224 image becomes 49 tokens of 768 dims (plus a class token).' }); wire(img, patch);
  y += 150;
  const vPos = add('positionalEncoding', 'vis_pos', { maxLen: 50, embedDim: 768 }, 150, y, { scope: 'vision' }); wire(patch, vPos);
  let vPrev = vPos;
  for (let i = 0; i < 12; i++) {
    y += 150;
    const b = add('transformerBlock', `vis_block_${i + 1}`, { embedDim: 768, numHeads: 12, ffDim: 3072 }, 150, y, { scope: `vision.layer.${i}`, notes: i === 0 ? 'Pre-norm ViT block (12 heads, MLP 3072, QuickGELU). One of 12.' : undefined });
    wire(vPrev, b); vPrev = b;
  }
  y += 150;
  const vNorm = add('layerNorm', 'vis_norm', { normalizedShape: 768 }, 150, y, { scope: 'vision' }); wire(vPrev, vNorm);
  y += 150;
  const vPool = add('globalAvgPool1d', 'vis_pool', {}, 150, y, { scope: 'vision', notes: 'Stand-in for class-token selection.' }); wire(vNorm, vPool);
  y += 150;
  const vProj = add('linear', 'img_proj', { inFeatures: 768, outFeatures: 512, bias: false }, 150, y, { scope: 'vision', notes: 'Projection into the shared 512-dim embedding space.' }); wire(vPool, vProj);
  // text tower
  let yt = 50;
  const tok = add('input', 'tokens', { shape: [1, 77] }, 650, yt, { notes: '77-token max context.' });
  yt += 150;
  const emb = add('embedding', 'tok_embed', { numEmbeddings: 49408, embeddingDim: 512 }, 650, yt, { scope: 'text', notes: '49408-token BPE vocabulary.' }); wire(tok, emb);
  yt += 150;
  const tPos = add('positionalEncoding', 'txt_pos', { maxLen: 77, embedDim: 512 }, 650, yt, { scope: 'text' }); wire(emb, tPos);
  let tPrev = tPos;
  for (let i = 0; i < 12; i++) {
    yt += 150;
    const b = add('transformerBlock', `txt_block_${i + 1}`, { embedDim: 512, numHeads: 8, ffDim: 2048 }, 650, yt, { scope: `text.layer.${i}`, notes: i === 0 ? 'Causal text block (8 heads, MLP 2048, QuickGELU). One of 12.' : undefined });
    wire(tPrev, b); tPrev = b;
  }
  yt += 150;
  const tNorm = add('layerNorm', 'txt_norm', { normalizedShape: 512 }, 650, yt, { scope: 'text' }); wire(tPrev, tNorm);
  yt += 150;
  const tPool = add('globalAvgPool1d', 'txt_pool', {}, 650, yt, { scope: 'text', notes: 'Stand-in for EOT-token selection.' }); wire(tNorm, tPool);
  yt += 150;
  const tProj = add('linear', 'txt_proj', { inFeatures: 512, outFeatures: 512, bias: false }, 650, yt, { scope: 'text', notes: 'Projection into the shared 512-dim embedding space.' }); wire(tPool, tProj);
  // joint space
  const maxY = Math.max(y, yt) + 150;
  const sim = add('matmul', 'similarity', {}, 400, maxY, { notes: 'Scaled dot product between L2-normalized image and text embeddings (learned temperature). Over a batch this is the NxN contrastive logit matrix.' });
  wire(vProj, sim); wire(tProj, sim);
  const out = add('output', 'logits', {}, 400, maxY + 150);
  wire(sim, out);
  return {
    id: 'clip-vit-b32', name: 'CLIP ViT-B/32',
    description: 'CLIP ViT-B/32 (OpenAI): contrastive image-text dual encoder. Full 12+12-block towers projected to a shared 512-dim space, scored by scaled dot product. Tower dims verified against the official config.json.',
    components: comps, connections: conns,
  };
}

function buildResNet50Full(): Graph {
  const comps: Comp[] = []; const conns: Conn[] = []; let ci = 0; let y = 50;
  const add = (type: string, name: string, params: Record<string, unknown>, opts: { x?: number; scope?: string; notes?: string; sameRow?: boolean } = {}) => {
    if (!opts.sameRow) y += 130;
    const c: Comp = { id: `${type}-${comps.length + 1}`, type, name, position: { x: opts.x ?? 300, y }, params, inputs: [], outputs: [] };
    if (opts.scope) c.scope = opts.scope; if (opts.notes) c.notes = opts.notes;
    comps.push(c); return c;
  };
  const wire = (a: Comp, b: Comp) => { conns.push({ id: `c${++ci}`, from: a.id, to: b.id }); };

  y -= 130;
  const inp = add('input', 'image', { shape: [3, 224, 224] });
  const stem = add('conv2d', 'conv1 7x7/2', { inChannels: 3, outChannels: 64, kernelSize: 7, stride: 2, padding: 3 }, { scope: 'stem' });
  wire(inp, stem);
  const stemBn = add('batchNorm', 'bn1', { numFeatures: 64 }, { scope: 'stem' }); wire(stem, stemBn);
  const stemRelu = add('relu', 'relu1', {}, { scope: 'stem' }); wire(stemBn, stemRelu);
  const pool = add('maxpool2d', 'maxpool 3x3/2', { kernelSize: 3, stride: 2, padding: 1 }, { scope: 'stem' }); wire(stemRelu, pool);

  let prev: Comp = pool;
  let inC = 64;
  const stages: Array<[mid: number, out: number, blocks: number]> = [[64, 256, 3], [128, 512, 4], [256, 1024, 6], [512, 2048, 3]];
  stages.forEach(([mid, out, blocks], si) => {
    for (let b = 0; b < blocks; b++) {
      const scope = `layer${si + 1}.${b}`;
      const stride = si > 0 && b === 0 ? 2 : 1;
      const blockIn = prev;
      const c1 = add('conv2d', `s${si + 1}b${b + 1} 1x1 ${mid}`, { inChannels: inC, outChannels: mid, kernelSize: 1 }, { scope, notes: b === 0 && si === 0 ? 'Bottleneck: 1x1 reduce, 3x3 conv, 1x1 expand. One of 16 blocks (3+4+6+3).' : undefined });
      wire(blockIn, c1);
      const bn1 = add('batchNorm', `s${si + 1}b${b + 1} bn1`, { numFeatures: mid }, { scope }); wire(c1, bn1);
      const r1 = add('relu', `s${si + 1}b${b + 1} relu1`, {}, { scope }); wire(bn1, r1);
      const c2 = add('conv2d', `s${si + 1}b${b + 1} 3x3 ${mid}${stride === 2 ? '/2' : ''}`, { inChannels: mid, outChannels: mid, kernelSize: 3, stride, padding: 1 }, { scope }); wire(r1, c2);
      const bn2 = add('batchNorm', `s${si + 1}b${b + 1} bn2`, { numFeatures: mid }, { scope }); wire(c2, bn2);
      const r2 = add('relu', `s${si + 1}b${b + 1} relu2`, {}, { scope }); wire(bn2, r2);
      const c3 = add('conv2d', `s${si + 1}b${b + 1} 1x1 ${out}`, { inChannels: mid, outChannels: out, kernelSize: 1 }, { scope }); wire(r2, c3);
      const bn3 = add('batchNorm', `s${si + 1}b${b + 1} bn3`, { numFeatures: out }, { scope }); wire(c3, bn3);
      let skipOut: Comp = blockIn;
      if (b === 0) {
        const ds = add('conv2d', `s${si + 1} downsample 1x1${stride === 2 ? '/2' : ''}`, { inChannels: inC, outChannels: out, kernelSize: 1, stride }, { scope, x: 620, sameRow: true, notes: 'Projection shortcut at the stage boundary.' });
        wire(blockIn, ds);
        const dsBn = add('batchNorm', `s${si + 1} ds bn`, { numFeatures: out }, { scope, x: 620 }); wire(ds, dsBn);
        skipOut = dsBn;
      }
      const sum = add('add', `s${si + 1}b${b + 1} add`, {}, { scope }); wire(bn3, sum); wire(skipOut, sum);
      const rOut = add('relu', `s${si + 1}b${b + 1} out`, {}, { scope }); wire(sum, rOut);
      prev = rOut;
      inC = out;
    }
  });
  const gap = add('globalAvgPool2d', 'avgpool', {}, { scope: 'head' }); wire(prev, gap);
  const fc = add('linear', 'fc 1000', { inFeatures: 2048, outFeatures: 1000 }, { scope: 'head' }); wire(gap, fc);
  const out = add('output', 'class_logits', {}); wire(fc, out);
  return {
    id: 'resnet-50', name: 'ResNet-50',
    description: 'ResNet-50 (He et al. 2015): full graph with all 16 bottleneck blocks (3+4+6+3), projection shortcuts at stage boundaries, GAP head. Parameter-faithful (25.6M).',
    components: comps, connections: conns,
  };
}

