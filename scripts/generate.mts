function layerTable(model: Graph): string {
  const compact = (p: Record<string, unknown>) => {
    const body = Object.entries(p).map(([k, v]) => `${k}: ${Array.isArray(v) ? `[${v.join(', ')}]` : String(v)}`).join(', ');
    return body || ' ';
  };
  return [
    '| # | Layer | Type | Params |',
    '|---|---|---|---|',
    ...model.components.map((c, i) => `| ${i + 1} | ${c.name} | \`${c.type}\` | ${compact(c.params)} |`),
  ].join('\n');
}

